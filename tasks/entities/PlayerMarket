{
  "name": "PlayerMarket",
  "type": "object",
  "properties": {
    "seller_id": {
      "type": "string"
    },
    "seller_name": {
      "type": "string"
    },
    "currency": {
      "type": "string",
      "enum": [
        "tokens",
        "diamonds"
      ],
      "default": "tokens"
    },
    "listing_type": {
      "type": "string",
      "enum": [
        "sell",
        "buy"
      ],
      "default": "sell"
    },
    "product_name": {
      "type": "string"
    },
    "quantity": {
      "type": "number",
      "default": 0
    },
    "price_per_unit": {
      "type": "number",
      "default": 0
    },
    "total_price": {
      "type": "number",
      "default": 0
    },
    "likes": {
      "type": "number",
      "default": 0
    },
    "liked_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Array of user IDs who liked this listing"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "sold",
        "cancelled"
      ],
      "default": "active"
    }
  },
  "required": [
    "seller_id",
    "seller_name",
    "currency",
    "listing_type",
    "product_name",
    "quantity",
    "price_per_unit"
  ]
}