# =============================================================
# GamingHub — Variáveis de Ambiente
# =============================================================
# Copie este ficheiro para .env e preencha com os seus valores
# do painel Supabase: https://supabase.com/dashboard/project/_/settings/api
# =============================================================

# URL do projeto Supabase (Project URL)
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Chave pública anon (anon / public key) — segura para o frontend
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================
# ATENÇÃO: As variáveis abaixo são APENAS para scripts locais
# e deploy. NUNCA as exponha no código do frontend.
# =============================================================

# Chave de serviço (service_role key) — apenas para migrações
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Referência do projeto (ex: kclflpvtdfqpunvguhvj)
SUPABASE_PROJECT_REF=SEU_PROJECT_REF

# Token do Vercel (para deploy via GitHub Actions)
VERCEL_TOKEN=SEU_VERCEL_TOKEN
VERCEL_ORG_ID=SEU_VERCEL_ORG_ID
VERCEL_PROJECT_ID=SEU_VERCEL_PROJECT_ID
